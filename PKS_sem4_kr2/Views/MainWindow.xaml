<Window x:Class="PKS_sem4_kr2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PKS_sem4_kr2"
        xmlns:viewModels="clr-namespace:PKS_sem4_kr2.ViewModels"
        mc:Ignorable="d"
        Title="Анализатор сетевых подключений" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <viewModels:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <local:BoolToColorConverter x:Key="BoolToColorConverter"/>
        
        <Style x:Key="InfoBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Анализатор сетевых подключений" 
                   FontSize="20" 
                   FontWeight="Bold" 
                   Margin="5" 
                   Grid.Row="0"/>

        <TabControl Grid.Row="1" Margin="0,5">
            <TabItem Header="Сетевые интерфейсы">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ListBox Grid.Column="0" 
                             ItemsSource="{Binding NetworkInterfaces}" 
                             SelectedItem="{Binding SelectedNetworkInterface}"
                             Margin="5">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding IpAddress}" FontSize="10" Foreground="Gray"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <ScrollViewer Grid.Column="2" Margin="5" VerticalScrollBarVisibility="Auto">
                        <Border Style="{StaticResource InfoBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Информация об интерфейсе" 
                                          FontWeight="Bold" 
                                          FontSize="14" 
                                          Margin="0,0,0,10"/>
                                
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" FontWeight="Bold"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedNetworkInterface.Name}" 
                                              Margin="5,0" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Описание:" FontWeight="Bold"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedNetworkInterface.Description}" 
                                              Margin="5,0" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="IP-адрес:" FontWeight="Bold"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedNetworkInterface.IpAddress}" 
                                              Margin="5,0"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Маска подсети:" FontWeight="Bold"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedNetworkInterface.SubnetMask}" 
                                              Margin="5,0"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="MAC-адрес:" FontWeight="Bold"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedNetworkInterface.MacAddress}" 
                                              Margin="5,0"/>

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Состояние:" FontWeight="Bold"/>
                                    <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="5,0">
                                        <Ellipse Width="10" Height="10" 
                                                Fill="{Binding SelectedNetworkInterface.IsOperational, 
                                                      Converter={StaticResource BoolToColorConverter}}" 
                                                Margin="0,5,5,5"/>
                                        <TextBlock Text="{Binding SelectedNetworkInterface.Status}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Скорость:" FontWeight="Bold"/>
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedNetworkInterface.SpeedFormatted}" 
                                              Margin="5,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="Анализ URL">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource InfoBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Введите URL для анализа:" FontWeight="Bold" Margin="0,0,0,5"/>
                            <DockPanel>
                                <Button Content="Анализировать" 
                                        Command="{Binding AnalyzeUrlCommand}" 
                                        Width="100" 
                                        Margin="0,0,10,0"
                                        Padding="5"
                                        DockPanel.Dock="Right"/>
                                <TextBox Text="{Binding InputUrl, UpdateSourceTrigger=PropertyChanged}" 
                                         Height="30"
                                         Padding="5"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource InfoBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Компоненты URL:" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Схема:" FontWeight="Bold"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding UrlComponents.Scheme}" 
                                          Margin="5,0"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Хост:" FontWeight="Bold"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding UrlComponents.Host}" 
                                          Margin="5,0"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Порт:" FontWeight="Bold"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding UrlComponents.Port}" 
                                          Margin="5,0"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Путь:" FontWeight="Bold"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding UrlComponents.Path}" 
                                          Margin="5,0"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Параметры:" FontWeight="Bold" VerticalAlignment="Top"/>
                                <ListBox Grid.Row="4" Grid.Column="1" 
                                        ItemsSource="{Binding UrlComponents.QueryParameters}"
                                        MaxHeight="100"
                                        Margin="5,0"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
                                                <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Key}" FontWeight="Bold" Foreground="DarkBlue"/>
                                                        <TextBlock Text=" = " Margin="5,0"/>
                                                        <TextBlock Text="{Binding Value}" Foreground="DarkGreen"/>
                                                    </StackPanel>
                                                </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Фрагмент:" FontWeight="Bold"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding UrlComponents.Fragment}" 
                                          Margin="5,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource InfoBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Дополнительная информация:" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <Button Content="Пинговать хост" 
                                        Command="{Binding PingHostCommand}"
                                        Width="120"
                                        Margin="5"
                                        Padding="5"/>
                                <Button Content="DNS информация" 
                                        Command="{Binding GetDnsInfoCommand}"
                                        Width="120"
                                        Margin="5"
                                        Padding="5"/>
                                <Button Content="Очистить историю" 
                                        Command="{Binding ClearHistoryCommand}"
                                        Width="120"
                                        Margin="5"
                                        Padding="5"/>
                            </StackPanel>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" 
                                        BorderBrush="LightGray" 
                                        BorderThickness="1" 
                                        Padding="5" 
                                        Margin="0,5"
                                        CornerRadius="3">
                                    <StackPanel>
                                        <TextBlock Text="Результат пинга:" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding PingResult}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" 
                                        BorderBrush="LightGray" 
                                        BorderThickness="1" 
                                        Padding="5" 
                                        Margin="0,5"
                                        CornerRadius="3">
                                    <StackPanel>
                                        <TextBlock Text="DNS информация:" FontWeight="Bold"/>
                                        
                                        <TextBlock Text="Хост:" FontWeight="Bold" Margin="0,5,0,0"/>
                                        <TextBlock Text="{Binding DnsInfo.HostName}" 
                                                  Margin="10,0"
                                                  TextWrapping="Wrap"/>
                                        
                                        <TextBlock Text="IP адреса:" FontWeight="Bold" Margin="0,5,0,0"/>
                                        <ListBox ItemsSource="{Binding DnsInfo.IpAddresses}" 
                                                 Margin="10,0"
                                                 MaxHeight="80">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}"/>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="2" 
                                        BorderBrush="LightGray" 
                                        BorderThickness="1" 
                                        Padding="5" 
                                        Margin="0,5"
                                        CornerRadius="3">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Тип адреса:" FontWeight="Bold" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding AddressType}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="3" Style="{StaticResource InfoBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="История проверок:" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                            <ListBox ItemsSource="{Binding UrlHistory}" 
                                     Height="100"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding AnalyzedAt, StringFormat=HH:mm:ss}"/>
                                            <TextBlock Text=" - "/>
                                            <TextBlock Text="{Binding Url}"/>
                                            <TextBlock Text=" ("/>
                                            <TextBlock Text="{Binding Host}"/>
                                            <TextBlock Text=")"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <StatusBar Grid.Row="2" Margin="0,5,0,0">
            <StatusBarItem>
                <TextBlock Text="Готов к работе"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
